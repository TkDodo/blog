---
interface Props {
  label: string;
  id?: string;
}

const { label, id } = Astro.props;
const tooltipId =
  id ??
  `abbr-${Math.random().toString(36).slice(2, 10)}-${Math.random()
    .toString(36)
    .slice(2, 10)}`;
---

<span class="tooltip">
  <abbr class="trigger" tabindex="0" title={label} aria-describedby={tooltipId}>
    <slot />
  </abbr>
  <span id={tooltipId} role="tooltip" class="content">
    {label}
  </span>
</span>

<style>
  .tooltip {
    position: relative;
    display: inline-block;
    vertical-align: baseline;
  }

  .trigger {
    cursor: help;
    font-size: inherit;
    line-height: inherit;
    text-decoration-line: underline;
    text-decoration-style: dotted;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
    text-decoration-color: color-mix(
      in srgb,
      var(--color-primary) 70%,
      transparent
    );
    border: 0;
  }

  .content {
    --tooltip-radius: 0.75rem;
    --tooltip-arrow-width: 0.5rem;
    --tooltip-arrow-height: 0.5rem;
    position: absolute;
    left: 50%;
    bottom: calc(100% + 0.65rem);
    z-index: 20;
    width: max-content;
    max-width: min(18rem, calc(100vw - 2rem));
    translate: -50% 0.35rem;
    border: 1px solid var(--color-ic-border);
    border-radius: var(--tooltip-radius);
    background: color-mix(in srgb, var(--color-bg) 94%, var(--color-ic-bg));
    color: var(--color-text);
    padding: 0.55rem 0.8rem;
    font-size: 0.8rem;
    line-height: 1.35;
    box-shadow:
      0 18px 30px -18px rgb(15 23 42 / 0.4),
      0 10px 18px -14px rgb(15 23 42 / 0.28);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 160ms ease,
      translate 160ms ease;
  }

  .content::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 100%;
    height: 0.75rem;
    width: 0.75rem;
    translate: -50% -50%;
    rotate: 45deg;
    border-right: 1px solid var(--color-ic-border);
    border-bottom: 1px solid var(--color-ic-border);
    background: color-mix(in srgb, var(--color-bg) 94%, var(--color-ic-bg));
  }

  @supports (border-shape: shape(from 0 0, line to 100% 0, close)) {
    .content {
      bottom: calc(100% + 0.3rem);
      padding-bottom: calc(0.55rem + var(--tooltip-arrow-height));
      border-shape: shape(
        from var(--tooltip-radius) 0,
        hline to calc(100% - var(--tooltip-radius)),
        curve to right var(--tooltip-radius) with right top,
        vline to
          calc(100% - (var(--tooltip-radius) + var(--tooltip-arrow-height))),
        curve to calc(100% - var(--tooltip-radius))
          calc(100% - var(--tooltip-arrow-height)) with right
          calc(100% - var(--tooltip-arrow-height)),
        hline to calc(50% + var(--tooltip-arrow-width)),
        line by calc(var(--tooltip-arrow-width) * -1)
          var(--tooltip-arrow-height),
        line by calc(var(--tooltip-arrow-width) * -1)
          calc(var(--tooltip-arrow-height) * -1),
        hline to var(--tooltip-radius),
        curve to left
          calc(100% - (var(--tooltip-radius) + var(--tooltip-arrow-height)))
          with left calc(100% - var(--tooltip-arrow-height)),
        vline to var(--tooltip-radius),
        curve to var(--tooltip-radius) top with left top
      );
    }

    .content::after {
      display: none;
    }
  }

  .tooltip:hover .content,
  .tooltip:focus-within .content {
    opacity: 1;
    translate: -50% 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .content {
      transition: opacity 0.01ms linear;
    }
  }
</style>
